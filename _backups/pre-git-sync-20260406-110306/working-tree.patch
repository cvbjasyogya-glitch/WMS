+        const startedAt = node.dataset.breakStartedAt || "";
+        const limitSeconds = Number.parseInt(node.dataset.breakLimitSeconds || "3600", 10);
+        const startedAtMs = Date.parse(startedAt);
+        if (!Number.isFinite(startedAtMs)) {
+            return;
+        }
+        const elapsedSeconds = Math.max(0, Math.floor((nowMs - startedAtMs) / 1000));
+        const remainingSeconds = Math.max(0, limitSeconds - elapsedSeconds);
+        const overLimitSeconds = Math.max(0, elapsedSeconds - limitSeconds);
+        const isOverLimit = overLimitSeconds > 0;
+        node.classList.toggle("is-over-limit", isOverLimit);
+        const valueNode = node.querySelector("[data-shell-break-value]");
+        if (valueNode) {
+            valueNode.textContent = isOverLimit
+                ? `+${formatShellBreakClock(overLimitSeconds)}`
