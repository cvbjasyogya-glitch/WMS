[Unit]
Description=Gunicorn WMS
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory=/root/WMS
EnvironmentFile=-/root/WMS/.env
RuntimeDirectory=wms
RuntimeDirectoryMode=0755
ExecStartPre=/usr/bin/rm -f /run/wms/gunicorn.sock
ExecStartPre=/usr/bin/python3 /root/WMS/scripts/backup_sqlite_db.py --database /root/WMS/database.db --output-dir /root/WMS/db_backups --retain-days 14
ExecStart=/usr/bin/python3 /usr/local/bin/gunicorn -w 4 --timeout 900 --graceful-timeout 60 --bind unix:/run/wms/gunicorn.sock --umask 007 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
