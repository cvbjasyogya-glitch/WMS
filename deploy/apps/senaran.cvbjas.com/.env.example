APP_ENV=production
FLASK_DEBUG=false
SECRET_KEY=change-this-to-a-long-random-secret
DEFAULT_ADMIN_PASSWORD=change-this-before-init-db
SENARAN_DATABASE=/var/www/queue-stringing-system/antrian.db
# DATABASE_PATH tetap didukung sebagai fallback jika service lama sudah memakai nama ini.
APP_TIMEZONE=Asia/Jakarta
SESSION_COOKIE_SECURE=true
BEHIND_PROXY=true
TRUSTED_HOSTS=senaran.cvbjas.com,127.0.0.1,localhost
