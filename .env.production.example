FLASK_ENV=production
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
ALLOWED_HOSTS=erp.cvbjasyogya.cloud
CANONICAL_HOST=erp.cvbjasyogya.cloud
CANONICAL_SCHEME=https
PUBLIC_BASE_URL=https://erp.cvbjasyogya.cloud
KIRIMI_BASE_URL=https://api.kirimi.id
KIRIMI_USER_CODE=
KIRIMI_DEVICE_ID=
KIRIMI_SECRET=
KIRIMI_TIMEOUT_SECONDS=15
WEBPUSH_SUBJECT=mailto:admin@cvbjasyogya.cloud
ANDROID_APP_PACKAGE=cloud.cvbjasyogya.erp
ANDROID_SHA256_CERT_FINGERPRINTS=
ANDROID_TWA_START_URL=https://erp.cvbjasyogya.cloud/workspace/?source=android-app
IOS_APP_IDS=
MEETING_PROVIDER=jitsi
JITSI_MEETING_DOMAIN=meet.jit.si
JITSI_ROOM_PREFIX=erp-bjas
JITSI_ROOM_MAX_PARTICIPANTS=10
MEETING_DEFAULT_LANGUAGE=id-ID
JITSI_JAAS_APP_ID=
JITSI_JAAS_KEY_ID=
JITSI_JAAS_PRIVATE_KEY_PATH=
JITSI_JAAS_PUBLIC_KEY_PATH=
JITSI_JAAS_KID=
JITSI_JAAS_TOKEN_TTL_SECONDS=7200
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=FULL
SQLITE_BUSY_TIMEOUT_MS=30000
SQLITE_TEMP_STORE=MEMORY
SQLITE_FOREIGN_KEYS=1
